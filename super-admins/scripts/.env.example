# Copy this to .env and fill in your values
# Used by both shell scripts and seed_school.py

# The static superadmin API key — must match SUPERADMIN_API_KEY on the server
SUPERADMIN_API_KEY=dev-superadmin-key

# Base URL of the running API server
API_BASE_URL=http://localhost:8000/api/v1

# Database URL — only needed for seed_school.py (direct DB provisioning)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/sms
