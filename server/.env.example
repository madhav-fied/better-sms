# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/sms

# Auth
SESSION_TTL_DAYS=37
SUPERADMIN_API_KEY=change-me-in-production

# OTP settings
OTP_TTL_MINUTES=10
OTP_MAX_ATTEMPTS=5
OTP_RATE_LIMIT_COUNT=3
OTP_RATE_LIMIT_MINUTES=15

# Dev mode: set to False in production to send real SMS
OTP_DEV_MODE=true

# Fast2SMS (required in production when OTP_DEV_MODE=false)
FAST2SMS_API_KEY=
FAST2SMS_SENDER_ID=SKEDUC
FAST2SMS_TEMPLATE_ID=
